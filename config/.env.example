# DFS-Optimizer — copy to repo root as .env and fill values
# Kelly, sheets, Telegram, IONOS deploy, etc.
# Do not commit .env; use GitHub Secrets for CI.

# The Odds API (the-odds-api.com) — NBA player props (replaces SGO)
ODDSAPI_KEY=
# Legacy alias (optional)
ODDS_API_KEY=
USE_ODDS_API=false

# Telegram (optional — for push notifications and run_optimizer --telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# IONOS dashboard deploy (optional — for npm run deploy:ftp and npm run web:deploy)
# deploy:ftp uses SFTP_SERVER, FTP_USERNAME, FTP_PASSWORD (daily-run step when set).
# web:deploy / web:deploy:only require all five; port 22 = SFTP.
SFTP_SERVER=
# or FTP_SERVER=  (alias for SFTP_SERVER)
FTP_USERNAME=
FTP_PASSWORD=
SFTP_PATH=
FTP_PORT=
