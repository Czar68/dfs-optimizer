# DFS-Optimizer — mirror of repository root `.env.example` (same KEY=value lines, same order).
# Copy either file to `.env` at the repo root; update both when adding variables (tests enforce parity).

# The Odds API (the-odds-api.com) — NBA player props (replaces SGO)
ODDSAPI_KEY=
# Legacy alias (optional)
ODDS_API_KEY=
USE_ODDS_API=false

# Odds snapshot health (merge coverage; auto mode rejects unhealthy cache when thresholds fail)
ODDS_SNAPSHOT_HEALTH_MIN_ROWS=200
ODDS_SNAPSHOT_HEALTH_MAX_PLACEHOLDER_SHARE=0.15
ODDS_SNAPSHOT_HEALTH_MIN_DISTINCT_STATS=2

# Telegram (optional — e.g. `--telegram`, daily driver when enabled)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web dashboard → IONOS /dfs/ (https://dfs.<domain>/) — optional; see npm run deploy / deploy:ftp / publish:dashboard-live
SFTP_SERVER=
FTP_USERNAME=
FTP_PASSWORD=
SFTP_SERVERdfs=
LIVE_DOMAIN=

# Phase AK (optional): boosted UD gate-order experiment — default off; CLI --ud-boosted-gate-experiment
UD_BOOSTED_GATE_EXPERIMENT=
# Phase AM (optional): pinned UD RawPick[] JSON for replay; CLI --ud-raw-picks-json <path>
# UD_RAW_PICKS_JSON=
# Phase AS/AT (default on): boosted-only builder viableLegs; 0|false disables when argv has neither UD builder toggle (explicit CLI wins)
# UD_BOOSTED_BUILDER_VIABLE_LEGS_EXPERIMENT=
