{
  "name": "dfs-optimizer",
  "version": "1.0.0",
  "description": "DFS lineup optimizer for PrizePicks and Underdog",
  "main": "dist/run_optimizer.js",
  "scripts": {
    "test": "jest",
    "fetch:underdog": "node -r ts-node/register src/debug_underdog_fetch.ts",
    "generate": "node scripts/run-generate.js",
    "generate:production": "node scripts/run-generate.js --platform both --bankroll 600 --volume --no-require-alt-lines",
    "test-volume": "jest --testPathPattern=prod.spec --testNamePattern=volume",
    "test-mock": "jest --testPathPattern=prod.spec --testNamePattern=mock",
    "build": "tsc",
    "sheets:setup": "python sheets_setup_9tab.py"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^128.0.0",
    "node-fetch": "^2.7.0",
    "playwright": "^1.40.0",
    "sports-odds-api": "^1.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "signal-exit": "^3.0.7",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
