# Copy to .env and fill in values. Do not commit .env.

# Cursor CLI (agent) — get key from https://cursor.com/account/api
CURSOR_API_KEY=

# Bankroll for Kelly stake sizing (default 1000 if unset)
BANKROLL=600

# Telegram bot (optional): for --telegram and --platform both
# Get token from @BotFather; get chat_id from getUpdates after adding bot to channel.
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_or_channel_id
# Optional: Sheets URL for Telegram message link (e.g. https://docs.google.com/spreadsheets/d/ID/edit)
TELEGRAM_SHEET_URL=

# TheRundown (TRD) API — optional third leg provider (--providers PP,UD,TRD)
# Free trial: contact therundown.io for 2-week key.
THERUNDOWN_API_KEY=sk-your_trial_key
