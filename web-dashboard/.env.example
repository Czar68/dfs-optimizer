# Copy to .env and set your backend URL.
# Used by the Pipeline dashboard to call POST /api/tasks and GET /api/logs.
# When the Vite dev server runs on a different port than the API, set this to the API origin.
VITE_API_URL=http://localhost:4000

# Production (IONOS): set to "data" so the dashboard loads CSVs from /dfs/data/ (deploy-ftp sets this at build time).
# Leave unset for local dev (uses /data/output_logs or API_BASE paths).
# VITE_DATA_BASE=data

# Phase 3 dashboard flag display (separate from Node runtime flags)
# VITE_ENABLE_ESPN_ENRICHMENT=true
# VITE_ENABLE_FANTASY_EV=true
# VITE_ENABLE_CALIBRATION_ADJEV=true
